{
  "name": "@demo-shop/source",
  "version": "0.3.71",
  "license": "MIT",
  "scripts": {
    "cm": "cz",
    "compodoc:backend": "npx @compodoc/compodoc -p apps/backend/tsconfig.app.json -d dist/docs/compodoc/backend",
    "compodoc:frontend": "npx @compodoc/compodoc -p apps/frontend/tsconfig.doc.json -d dist/docs/compodoc/frontend",
    "graph:backend": "nx graph --focus=backend --file=dist/docs/graph/backend/index.html",
    "graph:frontend": "nx graph --focus=frontend --file=dist/docs/graph/frontend/index.html",
    "start": "docker compose up -d",
    "rebuild": "docker compose up -d --build --remove-orphans",
    "openapi:generate": "rm -rf libs/api && openapi-generator generate -g typescript-angular -o libs/api -i http://localhost:3000/api/docs/v1/swagger.json -c open-api.yaml",
    "prepare": "husky",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate:dev": "npx prisma migrate dev",
    "prisma:reseed:dev": "npm run prisma:reset && npm run prisma:seed",
    "prisma:push": "npx prisma db push",
    "prisma:reset": "npx prisma db push --force-reset",
    "prisma:seed": "npx prisma db seed",
    "prisma:studio": "npx prisma studio",
    "release:major": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "storybook:build": "npx nx build-storybook frontend",
    "storybook:static": "npx nx static-storybook frontend",
    "storybook:serve": "npx nx storybook frontend",
    "storybook:test": "npx nx test-storybook frontend",
    "lint": "npx nx run-many -t lint",
    "test": "npx nx run-many -t test"
  },
  "private": true,
  "prisma": {
    "seed": "ts-node --project prisma/tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
